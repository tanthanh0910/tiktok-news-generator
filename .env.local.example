# =============================================
# Ollama (LLM local, miễn phí)
# Cài tại https://ollama.com → ollama pull llama3.1:latest
# =============================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:latest

# =============================================
# TTS provider: 'edge' (mặc định, chất lượng cao, đôi khi treo)
#               'gtts' (Google Translate, ổn định, voice cơ bản)
# Edge TTS sẽ tự fallback sang gTTS nếu lỗi/treo.
# =============================================
TTS_PROVIDER=edge
EDGE_TTS_VOICE=vi-VN-HoaiMyNeural

# =============================================
# YouTube Data API v3
# Cách tạo:
#   1. Vào https://console.cloud.google.com
#   2. Tạo project mới
#   3. Enable "YouTube Data API v3"
#   4. Credentials → OAuth 2.0 Client IDs → Web application
#   5. Authorized redirect URIs: http://localhost:3000/api/auth/youtube/callback
# =============================================
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# =============================================
# TikTok Content Posting API
# Cách tạo:
#   1. Vào https://developers.tiktok.com
#   2. Tạo app → Request "video.publish" scope
#   3. Thêm redirect URI: http://localhost:3000/api/auth/tiktok/callback
# =============================================
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback

# =============================================
# App config
# =============================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
